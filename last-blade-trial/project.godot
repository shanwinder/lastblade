; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LastBladeTrial"
run/main_scene="res://scenes/main/BossBrokenMaster.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[autoload]

UpgradeRunState="*res://upgrade_run_state.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[debug]

gdscript/warnings/shadowed_variable_base_class=0

[input]

attack={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"window_id":0,"physical_keycode":65,"unicode":97)
]
}
dash={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"window_id":0,"physical_keycode":83,"unicode":115)
]
}
parry={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"window_id":0,"physical_keycode":68,"unicode":100)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
